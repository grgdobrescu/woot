{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="float-end">
        <button type="submit" form="form-awb" class="btn btn-primary"><i class="fa-solid fa-barcode"></i> {{ button_generate }}</button>
        <a href="{{ back }}" class="btn btn-light"><i class="fa-solid fa-reply"></i></a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ol class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li class="breadcrumb-item"><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ol>
    </div>
  </div>
  <div class="container-fluid">
    <div class="card">
      <div class="card-header"><i class="fa-solid fa-box"></i> {{ text_awb_details }}</div>
      <div class="card-body">
        <div class="alert alert-info">
          <i class="fa-solid fa-info-circle"></i> {{ text_coming_soon }}
        </div>
        {# TODO: Implement AWB form with parcel details, recipient info, service selection #}
        {#
        <form id="form-awb" action="{{ action }}" method="post">
          <input type="hidden" name="order_id" value="{{ order_id }}"/>
          <fieldset>
            <legend>{{ text_parcel_details }}</legend>
            <div class="row mb-3">
              <label class="col-sm-2 col-form-label">{{ entry_weight }}</label>
              <div class="col-sm-10">
                <input type="number" name="weight" value="{{ weight }}" class="form-control" step="0.01"/>
              </div>
            </div>
            <div class="row mb-3">
              <label class="col-sm-2 col-form-label">{{ entry_dimensions }}</label>
              <div class="col-sm-10">
                <div class="row">
                  <div class="col-md-4">
                    <input type="number" name="length" value="{{ length }}" placeholder="{{ text_length }}" class="form-control"/>
                  </div>
                  <div class="col-md-4">
                    <input type="number" name="width" value="{{ width }}" placeholder="{{ text_width }}" class="form-control"/>
                  </div>
                  <div class="col-md-4">
                    <input type="number" name="height" value="{{ height }}" placeholder="{{ text_height }}" class="form-control"/>
                  </div>
                </div>
              </div>
            </div>
          </fieldset>
          <fieldset>
            <legend>{{ text_recipient }}</legend>
            <div class="row mb-3">
              <label class="col-sm-2 col-form-label">{{ entry_name }}</label>
              <div class="col-sm-10">
                <input type="text" name="recipient_name" value="{{ recipient_name }}" class="form-control"/>
              </div>
            </div>
            <div class="row mb-3">
              <label class="col-sm-2 col-form-label">{{ entry_phone }}</label>
              <div class="col-sm-10">
                <input type="text" name="recipient_phone" value="{{ recipient_phone }}" class="form-control"/>
              </div>
            </div>
            <div class="row mb-3">
              <label class="col-sm-2 col-form-label">{{ entry_address }}</label>
              <div class="col-sm-10">
                <textarea name="recipient_address" class="form-control" rows="3">{{ recipient_address }}</textarea>
              </div>
            </div>
          </fieldset>
        </form>
        #}
      </div>
    </div>
  </div>
</div>
{{ footer }}
